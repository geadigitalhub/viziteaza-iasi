<style>
:root{
  --navy:#141d33;
  --navy-2:#1b2848;
  --navy-3:#243459;
  --royal:#2E4488;
  --gold:#C9A24B;
  --gold-2:#E3C778;
  --gold-soft:#d9be7e;
  --cream:#F4ECD8;
  --cream-2:#EFE4C9;
  --paper:#FBF6EA;
  --teal:#3E7C8C;
  --brick:#A8362E;
  --blush:#DFA79E;
  --silver:#D7DBE1;
  --bronze:#7A5240;
  --ink:#1a2033;
  --muted:#6b7794;
  --line:rgba(201,162,75,.28);
  --r:18px;
  --maxw:1180px;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Jost',system-ui,sans-serif;color:var(--ink);background:var(--paper);line-height:1.7;overflow-x:hidden}
h1,h2,h3,.display{font-family:'Cormorant Garamond',Georgia,serif;font-weight:600;line-height:1.06}
a{color:inherit;text-decoration:none}
img{max-width:100%;display:block}
.wrap{max-width:var(--maxw);margin:0 auto;padding:0 26px}
.gold-text{color:var(--gold)}
.script{font-style:italic;font-weight:500}
.lang-en{display:none}
body.en .lang-ro{display:none}
body.en .lang-en{display:inline}
.overline{font-family:'Jost';font-weight:600;letter-spacing:.34em;text-transform:uppercase;font-size:.72rem}
.divider{display:inline-flex;align-items:center;gap:12px;color:var(--gold)}
.divider::before,.divider::after{content:"";width:34px;height:1px;background:var(--gold);opacity:.6}

/* ---------- NAV ---------- */
header.nav{position:sticky;top:0;z-index:60;background:rgba(20,29,51,.9);backdrop-filter:blur(12px);border-bottom:1px solid var(--line)}
.nav-inner{display:flex;align-items:center;justify-content:space-between;height:78px}
.logo{display:flex;flex-direction:column;line-height:1}
.logo b{font-family:'Cormorant Garamond';font-size:1.5rem;color:var(--cream);font-weight:700;letter-spacing:.5px}
.logo small{font-family:'Jost';letter-spacing:.34em;text-transform:uppercase;font-size:.58rem;color:var(--gold);margin-top:3px}
nav.links{display:flex;gap:32px;align-items:center}
nav.links a{font-weight:500;font-size:.86rem;letter-spacing:.06em;color:var(--cream);opacity:.82;transition:.2s;text-transform:uppercase}
nav.links a:hover{opacity:1;color:var(--gold-2)}
.nav-cta{display:flex;align-items:center;gap:16px}
.langsw{display:flex;border:1px solid var(--line);border-radius:30px;padding:3px}
.langsw button{border:0;background:transparent;padding:6px 12px;border-radius:24px;cursor:pointer;color:var(--cream);font-family:'Jost';font-weight:600;font-size:.76rem;letter-spacing:.08em;transition:.2s}
.langsw button.active{background:var(--gold);color:var(--navy)}
.btn{display:inline-flex;align-items:center;gap:9px;font-family:'Jost';font-weight:600;font-size:.82rem;letter-spacing:.12em;text-transform:uppercase;padding:14px 28px;border-radius:2px;cursor:pointer;border:0;transition:.3s}
.btn-gold{background:linear-gradient(120deg,var(--gold),var(--gold-2));color:var(--navy)}
.btn-gold:hover{transform:translateY(-2px);box-shadow:0 14px 30px -12px rgba(201,162,75,.7)}
.btn-outline{background:transparent;border:1px solid var(--gold);color:var(--gold)}
.btn-outline:hover{background:var(--gold);color:var(--navy)}
.btn-navy{background:var(--navy);color:var(--cream)}
.btn-navy:hover{background:var(--navy-3)}
.menu-toggle{display:none;background:none;border:0;font-size:24px;cursor:pointer;color:var(--gold)}

/* ---------- HERO ---------- */
.hero{position:relative;background:var(--navy);color:var(--cream);padding:96px 0 108px;overflow:hidden}
.hero::before{content:"";position:absolute;inset:0;z-index:0;
  background:
    radial-gradient(720px 460px at 80% 10%, rgba(46,68,136,.85), transparent 62%),
    radial-gradient(560px 420px at 12% 96%, rgba(62,124,140,.35), transparent 60%);}
.hero::after{content:"";position:absolute;inset:0;z-index:0;opacity:.5;
  background-image:radial-gradient(rgba(201,162,75,.14) 1px,transparent 1px);background-size:26px 26px;
  -webkit-mask-image:linear-gradient(180deg,transparent,#000 30%,#000 70%,transparent);mask-image:linear-gradient(180deg,transparent,#000 30%,#000 70%,transparent)}
.hero .wrap{position:relative;z-index:2}
.hero-inner{max-width:820px;margin:0 auto;text-align:center}
.hero .overline{color:var(--gold-2);margin-bottom:26px;display:inline-block}
.hero h1{font-size:clamp(3rem,7vw,5.6rem);color:var(--cream);letter-spacing:.5px}
.hero h1 .script{color:var(--gold-2)}
.hero .sub{font-size:1.2rem;color:rgba(244,236,216,.78);max-width:52ch;margin:28px auto 38px;font-weight:300}
.hero-actions{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:56px}
.hero-stats{display:flex;justify-content:center;gap:0;flex-wrap:wrap;border-top:1px solid var(--line);border-bottom:1px solid var(--line);max-width:720px;margin:0 auto}
.hero-stats .s{flex:1;min-width:150px;padding:26px 18px;border-right:1px solid var(--line)}
.hero-stats .s:last-child{border-right:0}
.hero-stats .s b{font-family:'Cormorant Garamond';font-size:2.3rem;color:var(--gold-2);display:block;line-height:1}
.hero-stats .s small{font-size:.72rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(244,236,216,.6);margin-top:8px;display:block}

/* ---------- STRIP ---------- */
.strip{background:linear-gradient(120deg,var(--gold),var(--gold-2));color:var(--navy);padding:16px 0;overflow:hidden}
.strip .row{display:flex;gap:52px;align-items:center;justify-content:center;flex-wrap:wrap;font-weight:600;letter-spacing:.18em;text-transform:uppercase;font-size:.78rem}
.strip .row span{display:flex;align-items:center;gap:52px}
.strip .dot{width:5px;height:5px;background:var(--navy);border-radius:50%}

/* ---------- SECTIONS ---------- */
section{padding:100px 0}
.sec-head{text-align:center;max-width:640px;margin:0 auto 60px}
.sec-head .overline{color:var(--gold);margin-bottom:16px;display:inline-block}
.sec-head h2{font-size:clamp(2.3rem,4.4vw,3.4rem);color:var(--navy)}
.sec-head p{color:var(--muted);font-size:1.08rem;margin-top:16px;font-weight:300}

/* ---------- REGIONS ---------- */
.reg-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
.reg{position:relative;border-radius:var(--r);overflow:hidden;min-height:320px;display:flex;align-items:flex-end;padding:26px;color:#fff;box-shadow:0 20px 44px -22px rgba(20,29,51,.55);transition:.4s}
.reg:hover{transform:translateY(-6px)}
.reg::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 30%,rgba(20,29,51,.86))}
.reg::before{content:"";position:absolute;inset:0;transition:.5s}
.reg:hover::before{transform:scale(1.06)}
.reg .c{position:relative;z-index:2}
.reg .overline{color:var(--gold-2);display:block;margin-bottom:8px}
.reg h3{font-size:1.9rem;color:#fff}
.reg p{font-size:.9rem;opacity:.82;font-weight:300;margin-top:6px}
.reg .go{position:relative;z-index:2;margin-top:16px;font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gold-2);font-weight:600}
.r1::before{background:linear-gradient(160deg,#2E4488,#141d33)}
.r2::before{background:linear-gradient(160deg,#3E7C8C,#1b3540)}
.r3::before{background:linear-gradient(160deg,#A8362E,#4a1712)}
.r4::before{background:linear-gradient(160deg,#7A5240,#2f1d15)}
.r5::before{background:linear-gradient(160deg,#243459,#141d33)}
.r6::before{background:linear-gradient(160deg,#B98A6B,#5a3b28)}
.reg.feat{grid-column:span 3;min-height:360px}
.reg.feat h3{font-size:2.6rem}
.reg .crown{position:absolute;top:22px;right:24px;z-index:2;font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;
  color:var(--navy);background:var(--gold-2);padding:6px 14px;border-radius:2px;font-weight:700}

/* ---------- IASI SPOTLIGHT ---------- */
#iasi{background:var(--navy);color:var(--cream);position:relative;overflow:hidden}
#iasi::before{content:"";position:absolute;inset:0;opacity:.5;
  background:radial-gradient(640px 460px at 88% 8%,rgba(46,68,136,.9),transparent 60%)}
#iasi .wrap{position:relative;z-index:2}
.iasi-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
#iasi .overline{color:var(--gold-2)}
#iasi h2{color:var(--cream);font-size:clamp(2.4rem,4.6vw,3.6rem);margin:14px 0 20px}
#iasi h2 .script{color:var(--gold-2)}
#iasi p.lead{color:rgba(244,236,216,.8);font-weight:300;font-size:1.08rem;margin-bottom:30px}
.iasi-list{display:grid;gap:2px;margin-bottom:34px}
.il{display:flex;gap:18px;padding:18px 0;border-bottom:1px solid var(--line);align-items:center}
.il .n{font-family:'Cormorant Garamond';font-size:1.5rem;color:var(--gold-2);width:38px;flex:0 0 auto}
.il b{color:var(--cream);font-size:1.05rem;font-weight:500}
.il small{color:rgba(244,236,216,.6);font-weight:300;display:block;font-size:.86rem}
.iasi-visual{position:relative}
.frame{border:1px solid var(--line);padding:14px;border-radius:4px;position:relative}
.frame .pic{border-radius:2px;min-height:440px;background:linear-gradient(155deg,#2E4488,#141d33);position:relative;overflow:hidden;display:flex;align-items:flex-end;padding:26px}
.frame .pic::after{content:"";position:absolute;top:-50px;right:-50px;width:230px;height:230px;border-radius:50%;
  background:radial-gradient(circle,rgba(227,199,120,.5),transparent 66%)}
.frame .pic .cap{position:relative;z-index:2}
.frame .pic .cap .overline{color:var(--gold-2)}
.frame .pic .cap h4{font-family:'Cormorant Garamond';font-size:2rem;color:#fff}
.plate{position:absolute;bottom:-26px;left:-26px;background:var(--gold);color:var(--navy);padding:18px 24px;border-radius:2px;box-shadow:0 18px 40px -18px rgba(0,0,0,.5)}
.plate b{font-family:'Cormorant Garamond';font-size:1.8rem;display:block;line-height:1}
.plate small{font-size:.66rem;letter-spacing:.18em;text-transform:uppercase;font-weight:600}

/* ---------- PRODUCTS ---------- */
#experiente{background:var(--paper)}
.exp-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px}
.exp{background:#fff;border:1px solid var(--line);border-radius:var(--r);overflow:hidden;transition:.35s;display:flex;flex-direction:column}
.exp:hover{transform:translateY(-6px);box-shadow:0 26px 50px -24px rgba(20,29,51,.4)}
.exp .top{height:150px;position:relative;display:flex;align-items:center;justify-content:center;color:#fff}
.exp .top .em{font-size:2.4rem}
.exp.e1 .top{background:linear-gradient(150deg,#2E4488,#141d33)}
.exp.e2 .top{background:linear-gradient(150deg,var(--teal),#1b3540)}
.exp.e3 .top{background:linear-gradient(150deg,var(--brick),#4a1712)}
.exp.e4 .top{background:linear-gradient(150deg,#3f7d54,#1d3a28)}
.exp.e5 .top{background:linear-gradient(150deg,#C9A24B,#a97f2e)}
a.exp{cursor:pointer}
.grp-label{color:var(--gold);text-align:center;letter-spacing:.28em;margin-bottom:18px;display:block}
.exp .top .ribbon{position:absolute;top:0;left:0;background:var(--gold);color:var(--navy);font-size:.62rem;letter-spacing:.14em;text-transform:uppercase;font-weight:700;padding:6px 14px}
.exp .in{padding:26px 26px 28px;flex:1;display:flex;flex-direction:column}
.exp h3{font-size:1.55rem;color:var(--navy)}
.exp p{color:var(--muted);font-size:.92rem;font-weight:300;margin:8px 0 18px}
.exp .foot{margin-top:auto;display:flex;align-items:center;justify-content:space-between;border-top:1px solid var(--line);padding-top:18px}
.exp .price{font-family:'Cormorant Garamond';font-size:1.7rem;color:var(--navy);font-weight:700}
.exp .price small{font-family:'Jost';font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);font-weight:500;display:block}
.exp .arrow{color:var(--gold);font-weight:600;font-size:.76rem;letter-spacing:.14em;text-transform:uppercase}

/* ---------- GALLERY ---------- */
#galerie{background:var(--navy);color:var(--cream)}
#galerie .sec-head h2{color:var(--cream)}
#galerie .sec-head p{color:rgba(244,236,216,.7)}
.gal{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:170px;gap:14px}
.g{position:relative;border-radius:6px;overflow:hidden;display:flex;align-items:flex-end;padding:16px;color:#fff;cursor:pointer;transition:.4s;border:1px solid var(--line)}
.g:hover{transform:scale(1.02)}
.g::after{content:"";position:absolute;inset:0;background:linear-gradient(transparent 42%,rgba(20,29,51,.82))}
.g span{position:relative;z-index:2;font-family:'Cormorant Garamond';font-size:1.15rem;font-weight:600}
.g .up{position:absolute;z-index:2;top:12px;left:12px;font-size:.6rem;letter-spacing:.14em;text-transform:uppercase;background:rgba(201,162,75,.85);color:var(--navy);padding:4px 9px;border-radius:2px;font-weight:700}
.g.big{grid-column:span 2;grid-row:span 2}
.g.wide{grid-column:span 2}
.ga{background:linear-gradient(150deg,#2E4488,#141d33)}
.gb{background:linear-gradient(150deg,var(--teal),#1b3540)}
.gc{background:linear-gradient(150deg,var(--brick),#4a1712)}
.gd{background:linear-gradient(150deg,var(--bronze),#2f1d15)}
.ge{background:linear-gradient(150deg,#B98A6B,#5a3b28)}
.gf{background:linear-gradient(150deg,#243459,#141d33)}
.gal-note{text-align:center;margin-top:28px;color:rgba(244,236,216,.7);font-weight:300;font-size:.94rem}
.gal-note b{color:var(--gold-2);font-weight:500}

/* ---------- BOOKING ---------- */
#rezervari{background:var(--cream-2)}
.book-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.bk{background:var(--paper);border:1px solid var(--line);border-radius:var(--r);padding:32px 28px;text-align:center}
.bk .em{font-size:2rem}
.bk h3{font-size:1.5rem;color:var(--navy);margin:14px 0 8px}
.bk p{color:var(--muted);font-weight:300;font-size:.9rem}
.bk .soon{display:inline-block;margin-top:16px;font-size:.64rem;letter-spacing:.16em;text-transform:uppercase;font-weight:700;color:var(--gold);border:1px solid var(--gold);padding:6px 14px;border-radius:2px}

/* ---------- CTA ---------- */
.cta{background:var(--navy);color:var(--cream);text-align:center;position:relative;overflow:hidden}
.cta::before{content:"";position:absolute;inset:0;opacity:.5;background:radial-gradient(620px 420px at 50% 0%,rgba(46,68,136,.8),transparent 62%)}
.cta .wrap{position:relative;z-index:2}
.cta h2{font-size:clamp(2.2rem,4.4vw,3.4rem);color:var(--cream)}
.cta h2 .script{color:var(--gold-2)}
.cta p{color:rgba(244,236,216,.75);font-weight:300;max-width:48ch;margin:18px auto 30px}
.news{display:flex;gap:12px;max-width:460px;margin:0 auto;flex-wrap:wrap;justify-content:center}
.news input{flex:1;min-width:240px;border:1px solid var(--line);background:rgba(255,255,255,.06);color:var(--cream);border-radius:2px;padding:15px 20px;font-family:'Jost';font-size:.9rem}
.news input::placeholder{color:rgba(244,236,216,.5)}

/* ---------- FOOTER ---------- */
footer{background:#0f1728;color:var(--cream);padding:60px 0 30px}
.foot-grid{display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:36px;margin-bottom:40px}
footer .logo b{font-size:1.6rem}
footer p.about{color:rgba(244,236,216,.6);font-weight:300;font-size:.9rem;margin-top:16px;max-width:32ch}
footer h5{font-family:'Jost';font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:18px}
footer ul{list-style:none}
footer ul li{margin-bottom:11px}
footer ul li a{color:rgba(244,236,216,.72);font-size:.9rem;font-weight:300;transition:.2s}
footer ul li a:hover{color:var(--gold-2)}
.foot-bottom{border-top:1px solid var(--line);padding-top:22px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;color:rgba(244,236,216,.5);font-size:.82rem;font-weight:300}

@media(max-width:900px){
  .reg-grid,.exp-grid,.book-grid{grid-template-columns:1fr}
  .reg.feat{grid-column:span 1}
  .iasi-grid{grid-template-columns:1fr;gap:56px}
  .gal{grid-template-columns:repeat(2,1fr)}
  .g.big{grid-column:span 2;grid-row:span 1}
  nav.links{display:none}
  .menu-toggle{display:block}
  .foot-grid{grid-template-columns:1fr 1fr}
  .strip .row{gap:26px}.strip .row span{gap:26px}
}
@media(max-width:560px){.foot-grid{grid-template-columns:1fr}}
</style>
</head>
